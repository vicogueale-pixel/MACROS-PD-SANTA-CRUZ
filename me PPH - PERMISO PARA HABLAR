<!DOCTYPE html>
<html>
<head>
<title>Comandos</title>
<style>
body {
    font-family: Arial;
}

.comando {
    display: flex;
    align-items: center;
    margin: 10px;
    padding: 10px;
    border: 1px solid #ccc;
}

button {
    margin-left: 10px;
    cursor: pointer;
}
</style>
</head>

<body>

<h1>Comandos</h1>

<div class="comando">
<span id="cmd1">/me PPH - PERMISO PARA HABLAR</span>
<button onclick="copiar('cmd1')">📋</button>
</div>

<script>
function copiar(id) {
    let texto = document.getElementById(id).innerText;
    navigator.clipboard.writeText(texto);
    alert("Comando copiado");
}
</script>

</body>
</html>
